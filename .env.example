# Environment variables for BluNoro
# Copy this file to .env and update the values

# Database Configuration
DB_USER=blunoro
DB_PASSWORD=secure_database_password_change_me
DB_NAME=blunoro

# RabbitMQ Configuration
RABBITMQ_USER=blunoro
RABBITMQ_PASSWORD=secure_rabbitmq_password_change_me

# Redis Configuration  
REDIS_PASSWORD=secure_redis_password_change_me

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_me_immediately

# Grafana Configuration
GRAFANA_PASSWORD=secure_grafana_password_change_me

# SMTP Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@domain.com
SMTP_PASSWORD=your_email_password_or_app_password

# Application Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80

# Logging
SERILOG_MINIMUM_LEVEL=Information
ELASTICSEARCH_URL=http://elasticsearch:9200